                str(p.get("odeme_tarihi",""))[:10],
                p.get("ad_soyad",""), p.get("gorev",""), odenen
            ], 1):
                c = ws4.cell(row=r, column=col, value=val)
                if col == 4: c.number_format = '#,##0'
                border(c)
            r += 1
        c = ws4.cell(row=r, column=3, value="TOPLAM")
