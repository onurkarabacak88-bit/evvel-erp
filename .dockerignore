                if col > 1: c.number_format = '#,##0'
                c.alignment = Alignment(horizontal='right' if col>1 else 'left')
                border(c)
            r += 1

    # ════════════════════════════════════════════════════════════
    # SAYFA 4: GİDER DETAYLARI
    # ════════════════════════════════════════════════════════════
    ws4 = wb.create_sheet("Gider Detayları")
