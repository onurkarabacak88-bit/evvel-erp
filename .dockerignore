            """
            INSERT INTO siparis_kategori (kod, ad, emoji, sira, aktif)
            VALUES (
                %s, %s, %s,
                COALESCE((SELECT MAX(sira)+10 FROM siparis_kategori), 10),
                TRUE
            )
            RETURNING id, kod, ad
            """,
            (kod, ad, emoji),
        )
        row = dict(cur.fetchone())
        audit(cur, "siparis_kategori", str(row["id"]), "OPS_SIP_KATEGORI")
